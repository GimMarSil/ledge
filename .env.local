# =============================================================
# Despesas & Fiscal — Módulo BuildFlow
# Configuração para desenvolvimento local
# =============================================================

# ── App ──────────────────────────────────────────────────────
PORT=7331
BASE_URL=http://localhost:7331
SELF_HOSTED_MODE=true
DISABLE_SIGNUP=true

# ── Base de dados (PostgreSQL local via Docker) ──────────────
DATABASE_URL="postgresql://ledge:ledge@localhost:5433/ledge"
UPLOAD_PATH="./data/uploads"

# ── Auth ─────────────────────────────────────────────────────
BETTER_AUTH_SECRET="ledge-despesas-fiscal-secret-key-please-change-2026"

# ── LLM Providers (Azure OpenAI) ────────────────────────────
OPENAI_API_KEY=3RxRsPb4Dyq8VZtlenFie8ogVon4QsVq1uVSXEyJ1PhgNMvEEWRlJQQJ99BEACfhMk5XJ3w3AAABACOGtRfE
OPENAI_MODEL_NAME=gpt-4o-mini

GOOGLE_MODEL_NAME=gemini-2.5-flash
GOOGLE_API_KEY=

MISTRAL_MODEL_NAME=mistral-medium-latest
MISTRAL_API_KEY=

# ── Email (opcional em dev) ──────────────────────────────────
RESEND_API_KEY=re_placeholder_set_real_key_in_production
RESEND_FROM_EMAIL="Despesas & Fiscal <noreply@buildflow.pt>"
RESEND_AUDIENCE_ID=

# ── Stripe (opcional em dev) ─────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── BuildFlow Integration ────────────────────────────────────
BUILDFLOW_MODULE=true
BUILDFLOW_API_KEY=bf_dev_api_key_change_in_production

# ── AT / Autoridade Tributária (opcional até certificação) ───
AT_SIGNING_PRIVATE_KEY=
AT_CERTIFICATE_NUMBER=0
